# Set these in the Vercel project dashboard (Settings → Environment Variables)
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER/DBNAME?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
BACKEND_ENCRYPTION_KEY=backend-secret-key-change-in-production-32chars!
FRONTEND_ENCRYPTION_KEY=frontend-secret-key-change-in-production-32char!

# Build-time var for the React client (also set in Vercel)
REACT_APP_FRONTEND_ENCRYPTION_KEY=frontend-secret-key-change-in-production-32char!
